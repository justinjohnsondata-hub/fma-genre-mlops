# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# --- Virtual environments (regenerable from requirements.txt) ---
.venv/
venv/
env/

# --- Test / tooling caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- DVC (track pointers, not the cache or pulled data) ---
/.dvc/cache/
/.dvc/tmp/
/data/

# --- MLflow (local tracking store + artifacts) ---
mlruns/
mlartifacts/

# --- Evidently reports (regenerable HTML) ---
*.html

# --- OS / editor cruft ---
.DS_Store
*.swp
